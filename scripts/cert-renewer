#!/usr/bin/env bash
# Renew or obtain Let's Encrypt certs (DNS-01 via Cloudflare) for home-warden.
#
# Configuration (gitignored runtime files; examples under conf/):
#   conf/certbot-domains   — one domain per line
#   conf/cloudflare.ini    — dns_cloudflare_api_token=…
#
# Env overrides:
#   SCRATCH_DIR
#   CERTBOT_CONFIG_DIR     default: $scratch_dir/certs
#   CLOUDFLARE_CREDENTIALS default: $repo_dir/conf/cloudflare.ini
#   CERTBOT_EMAIL          default: admin@example.com (set a real address for LE)
#   HOME_WARDEN_RELOAD     default: 1 (set 0 when systemd ExecStartPost reloads)
#   CERTBOT_DOMAINS_FILE   default: $repo_dir/conf/certbot-domains
#
# Usage:
#   ./scripts/cert-renewer
#   ./scripts/cert-renewer --dry-run
# Logs (timer): ~/scratch/home-warden/cert-renewer.log

set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
readonly script_dir
repo_dir="$(cd "${script_dir}/.." && pwd)"
readonly repo_dir

scratch_dir="${SCRATCH_DIR:-${HOME}/scratch/home-warden}"
certbot_config_dir="${CERTBOT_CONFIG_DIR:-${scratch_dir}/certs}"
cloudflare_credentials="${CLOUDFLARE_CREDENTIALS:-${repo_dir}/conf/cloudflare.ini}"
certbot_email="${CERTBOT_EMAIL:-admin@example.com}"
home_warden_reload="${HOME_WARDEN_RELOAD:-1}"
certbot_domains_file="${CERTBOT_DOMAINS_FILE:-${repo_dir}/conf/certbot-domains}"
certbot_bin="${CERTBOT:-/usr/bin/certbot}"
dry_run=0

usage() {
  cat <<'EOF'
Usage: cert-renewer [--dry-run] [-h|--help]

Obtain or renew certificates listed in CERTBOT_DOMAINS_FILE (DNS-01 Cloudflare).
  --dry-run   Pass --dry-run to certbot (no lasting cert changes)
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --dry-run) dry_run=1 ;;
    -h | --help)
      usage
      exit 0
      ;;
    *)
      echo "Unknown argument: $1" >&2
      usage >&2
      exit 2
      ;;
  esac
  shift
done

trim_ws() {
  local s=$1
  s="${s#"${s%%[![:space:]]*}"}"
  s="${s%"${s##*[![:space:]]}"}"
  printf '%s' "${s}"
}

# Fills nameref array; returns 2 on missing file / no domains (exit propagates).
load_domains() {
  local -n out_domains=$1
  local line trimmed
  out_domains=()
  if [[ ! -f "${certbot_domains_file}" ]]; then
    echo "cert-renewer: missing domains file: ${certbot_domains_file}" >&2
    echo "  copy conf/certbot-domains.example → conf/certbot-domains" >&2
    return 2
  fi
  while IFS= read -r line || [[ -n "${line}" ]]; do
    [[ "${line}" =~ ^[[:space:]]*# ]] && continue
    trimmed="$(trim_ws "${line}")"
    [[ -z "${trimmed}" ]] && continue
    out_domains+=("${trimmed}")
  done <"${certbot_domains_file}"
  if ((${#out_domains[@]} == 0)); then
    echo "cert-renewer: no domains listed in ${certbot_domains_file}" >&2
    return 2
  fi
  return 0
}

if [[ ! -x "${certbot_bin}" ]]; then
  echo "cert-renewer: certbot not found at ${certbot_bin}" >&2
  echo "  sudo apt-get install -y certbot python3-certbot-dns-cloudflare" >&2
  exit 2
fi
if [[ ! -f "${cloudflare_credentials}" ]]; then
  echo "cert-renewer: Cloudflare credentials missing: ${cloudflare_credentials}" >&2
  echo "  copy conf/cloudflare.ini.example → conf/cloudflare.ini" >&2
  exit 2
fi
if [[ "${certbot_email}" == "admin@example.com" && "${dry_run}" -eq 0 ]]; then
  echo "cert-renewer: WARNING: CERTBOT_EMAIL is still admin@example.com — set a real contact for production issuance" >&2
fi

mkdir -p "${certbot_config_dir}" "${scratch_dir}/logs/certbot"
: >>"${scratch_dir}/cert-renewer.log" 2>/dev/null || true

domains=()
load_domains domains
echo "cert-renewer: config-dir=${certbot_config_dir} domains=${#domains[@]} dry_run=${dry_run}"

dry_run_args=()
if ((dry_run)); then
  dry_run_args+=(--dry-run)
fi

for domain in "${domains[@]}"; do
  live_cert="${certbot_config_dir}/live/${domain}/fullchain.pem"
  if [[ -f "${live_cert}" ]]; then
    echo "cert-renewer: renew existing ${domain}"
    "${certbot_bin}" renew \
      --server https://acme-v02.api.letsencrypt.org/directory \
      --dns-cloudflare \
      --dns-cloudflare-credentials "${cloudflare_credentials}" \
      --preferred-challenges dns-01 \
      --work-dir "${certbot_config_dir}" \
      --logs-dir "${scratch_dir}/logs/certbot" \
      --config-dir "${certbot_config_dir}" \
      -m "${certbot_email}" \
      --agree-tos \
      --cert-name "${domain}" \
      --non-interactive \
      "${dry_run_args[@]}"
  else
    echo "cert-renewer: obtain new certificate for ${domain}"
    "${certbot_bin}" certonly \
      -d "${domain}" \
      --cert-name "${domain}" \
      --server https://acme-v02.api.letsencrypt.org/directory \
      --dns-cloudflare \
      --dns-cloudflare-credentials "${cloudflare_credentials}" \
      --preferred-challenges dns-01 \
      --work-dir "${certbot_config_dir}" \
      --logs-dir "${scratch_dir}/logs/certbot" \
      --config-dir "${certbot_config_dir}" \
      -m "${certbot_email}" \
      --agree-tos \
      --non-interactive \
      "${dry_run_args[@]}"
  fi
done

if ((dry_run == 0)); then
  chmod -R u+rwX,g+rX,o-rwx "${certbot_config_dir}" || true
  find "${certbot_config_dir}/live" -type f -name 'privkey.pem' -exec chmod 640 {} \; 2>/dev/null || true
fi

if [[ "${home_warden_reload}" == "1" ]] && ((dry_run == 0)); then
  if systemctl is-active --quiet home-warden.service 2>/dev/null; then
    echo "cert-renewer: reloading home-warden.service"
    if ! sudo systemctl reload home-warden.service; then
      echo "cert-renewer: reload failed — trying restart" >&2
      if ! sudo systemctl restart home-warden.service; then
        echo "cert-renewer: ERROR: could not reload/restart home-warden.service" >&2
        exit 1
      fi
    fi
  else
    echo "cert-renewer: home-warden.service not active — skip reload"
  fi
fi

echo "cert-renewer: done"
