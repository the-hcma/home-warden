#!/usr/bin/env bash
# Install home-warden system socket + service (privileged ports via systemd).
# Expands etc/systemd templates into /etc/systemd/system/ with sudo.
#
# Placeholders: @@OWNER@@ @@SCRATCH_DIR@@ @@HOME_NGINX_CONF@@
# Injects ConditionHost=|<machine-id> and ConditionHost=|<hostname> (OR).
#
# Flow (non-dry-run):
#   1. Prompt for sudo (credential cache)
#   2. Verify packages / home nginx.conf / unit templates
#   3. Prepare scratch runtime (logs, modules symlink)
#   4. Validate nginx config (sudo nginx -t) — abort if invalid
#   5. Run on-deploy (when present), install units, mask distro nginx, start service
#
# Usage:
#   ./scripts/setup-service [--status] [--dry-run]
#   HOME_NGINX_CONF=/path/to/home/nginx/server/nginx.conf ./scripts/setup-service
#
# Env overrides:
#   HOME_NGINX_CONF  Absolute path to thehcma/home nginx.conf
#   OWNER            Service user (default: current user)
#   SCRATCH_DIR      Runtime prefix for nginx -p (default: ~/scratch/home-warden)

set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
readonly script_dir
repo_dir="$(cd "${script_dir}/.." && pwd)"
readonly repo_dir
readonly unit_template_dir="${repo_dir}/etc/systemd"
readonly system_unit_dir="/etc/systemd/system"
readonly host_config_dir="${HOME}/.config"
readonly host_name_file="${host_config_dir}/user-services-host"
readonly host_machine_id_file="${host_config_dir}/user-services-machine-id"
readonly host_fqdn_file="${host_config_dir}/user-services-host-fqdn"

OWNER="${OWNER:-$(id -un)}"
SCRATCH_DIR="${SCRATCH_DIR:-${HOME}/scratch/home-warden}"
HOME_NGINX_CONF="${HOME_NGINX_CONF:-}"
DEPLOYED_COMMIT="${DEPLOYED_COMMIT:-}"
readonly default_home_nginx_conf="${HOME}/home/nginx/server/nginx.conf"

dry_run=0
status_only=0

usage() {
  cat <<'EOF'
Usage: setup-service [--status] [--dry-run] [-h|--help]

Install/enable home-warden.socket + home-warden.service into /etc/systemd/system.
Prompts for sudo, validates nginx -t, then starts the service when validation passes.

  --status   Show resolved paths and unit state; do not install
  --dry-run  Print actions without writing units or calling systemctl
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --status) status_only=1 ;;
    --dry-run) dry_run=1 ;;
    -h | --help)
      usage
      exit 0
      ;;
    *)
      echo "Unknown argument: $1" >&2
      usage >&2
      exit 2
      ;;
  esac
  shift
done

current_hostname_short() {
  hostname -s 2>/dev/null || hostname
}

machine_id_local() {
  tr -d '[:space:]' </etc/machine-id
}

ensure_host_config() {
  mkdir -p "${host_config_dir}"
  if [[ ! -f "${host_name_file}" ]]; then
    current_hostname_short >"${host_name_file}"
  fi
  if [[ ! -f "${host_machine_id_file}" ]]; then
    machine_id_local >"${host_machine_id_file}"
  fi
  if [[ ! -f "${host_fqdn_file}" ]]; then
    hostname >"${host_fqdn_file}" || current_hostname_short >"${host_fqdn_file}"
  fi
}

resolve_home_nginx_conf() {
  if [[ -n "${HOME_NGINX_CONF}" ]]; then
    printf '%s\n' "${HOME_NGINX_CONF}"
    return 0
  fi
  if [[ -f "${default_home_nginx_conf}" ]]; then
    printf '%s\n' "${default_home_nginx_conf}"
    return 0
  fi
  if [[ -f /home/house_meister/home/nginx/server/nginx.conf ]]; then
    printf '%s\n' /home/house_meister/home/nginx/server/nginx.conf
    return 0
  fi
  return 1
}

run() {
  if ((dry_run)); then
    printf 'DRY-RUN:'
    printf ' %q' "$@"
    printf '\n'
    return 0
  fi
  "$@"
}

require_sudo() {
  if ((dry_run)); then
    echo "DRY-RUN: would prompt for sudo credentials"
    return 0
  fi
  echo "Requesting sudo credentials (needed for units, nginx -t, and masking distro nginx)..."
  if ! sudo -v; then
    echo "ERROR: sudo authentication failed" >&2
    exit 1
  fi
}

config_file_first_line() {
  local -r path="$1"
  local line=""
  IFS= read -r line <"${path}" || true
  printf '%s\n' "${line}"
}

package_installed() {
  local -r pkg="$1"
  dpkg-query -W -f='${Status}' "${pkg}" 2>/dev/null | grep -q 'install ok installed'
}

check_prerequisites() {
  local missing=0
  local pkg

  if ! command -v nginx >/dev/null 2>&1; then
    echo "ERROR: nginx not on PATH — sudo apt-get install -y nginx libnginx-mod-stream" >&2
    missing=1
  fi
  for pkg in nginx libnginx-mod-stream; do
    if ! package_installed "${pkg}"; then
      echo "ERROR: package ${pkg} not installed — sudo apt-get install -y nginx libnginx-mod-stream" >&2
      missing=1
    fi
  done
  if [[ ! -f "${unit_template_dir}/home-warden.service" || ! -f "${unit_template_dir}/home-warden.socket" ]]; then
    echo "ERROR: missing unit templates under ${unit_template_dir}" >&2
    missing=1
  fi
  if [[ ! -f "${HOME_NGINX_CONF}" ]]; then
    echo "ERROR: HOME_NGINX_CONF not found: ${HOME_NGINX_CONF}" >&2
    missing=1
  fi
  if ((missing)); then
    exit 1
  fi
  echo "Prerequisites OK (nginx + stream module + conf + unit templates)"
}

prepare_scratch() {
  run mkdir -p \
    "${SCRATCH_DIR}/logs" \
    "${SCRATCH_DIR}/certs/live" \
    "${SCRATCH_DIR}/client_body_temp" \
    "${SCRATCH_DIR}/proxy_temp" \
    "${SCRATCH_DIR}/fastcgi_temp" \
    "${SCRATCH_DIR}/uwsgi_temp" \
    "${SCRATCH_DIR}/scgi_temp"
  if [[ -d /usr/lib/nginx/modules ]]; then
    run ln -sfn /usr/lib/nginx/modules "${SCRATCH_DIR}/modules"
  fi
  if ((dry_run)); then
    echo "DRY-RUN: would touch ${SCRATCH_DIR}/home-warden.log and logs/{error,access}.log"
  else
    local log
    for log in \
      "${SCRATCH_DIR}/home-warden.log" \
      "${SCRATCH_DIR}/logs/error.log" \
      "${SCRATCH_DIR}/logs/access.log"; do
      if ! touch "${log}"; then
        echo "ERROR: cannot create log file ${log} (is SCRATCH_DIR writable?)" >&2
        exit 1
      fi
    done
  fi
}

validate_nginx_config() {
  echo "Validating nginx config (sudo nginx -t)..."
  if ((dry_run)); then
    echo "DRY-RUN: sudo nginx -p ${SCRATCH_DIR}/ -t -c ${HOME_NGINX_CONF}"
    return 0
  fi
  if ! sudo nginx -p "${SCRATCH_DIR}/" -t -c "${HOME_NGINX_CONF}"; then
    echo "ERROR: nginx -t failed — refusing to install/start home-warden" >&2
    exit 1
  fi
  echo "nginx -t OK"
}

expand_unit() {
  local -r src="$1"
  local -r dest="$2"
  local generated
  local host_name
  local machine_id
  local tmp

  host_name="$(config_file_first_line "${host_name_file}")"
  machine_id="$(config_file_first_line "${host_machine_id_file}")"

  generated="$(
    sed \
      -e "s|@@OWNER@@|${OWNER}|g" \
      -e "s|@@SCRATCH_DIR@@|${SCRATCH_DIR}|g" \
      -e "s|@@HOME_NGINX_CONF@@|${HOME_NGINX_CONF}|g" \
      -e "s|@@REPO_DIR@@|${repo_dir}|g" \
      -e "s|@@DEPLOYED_COMMIT@@|${DEPLOYED_COMMIT}|g" \
      "${src}"
  )"

  generated="$(
    awk -v mid="${machine_id}" -v host="${host_name}" '
      BEGIN { done = 0 }
      /^\[Unit\]$/ && !done {
        print
        print "# Service host guard (OR): machine-id or hostname"
        # Adjacent string+var concatenates (no OFS space); | prefixes OR-group.
        printf "ConditionHost=|%s\n", mid
        printf "ConditionHost=|%s\n", host
        done = 1
        next
      }
      { print }
    ' <<<"${generated}"
  )"

  if ((dry_run)); then
    echo "DRY-RUN: would write ${dest}"
    echo "-----"
    printf '%s\n' "${generated}"
    echo "-----"
    return 0
  fi

  tmp="$(mktemp)"
  printf '%s\n' "${generated}" >"${tmp}"
  run sudo install -o root -g root -m 644 "${tmp}" "${dest}"
  rm -f "${tmp}"
}

run_on_deploy() {
  local -r hook="${repo_dir}/scripts/on-deploy"
  local rc=0
  if [[ ! -x "${hook}" ]]; then
    echo "WARNING: ${hook} missing or not executable — skipping on-deploy" >&2
    return 0
  fi
  echo "Running scripts/on-deploy..."
  if ((dry_run)); then
    echo "DRY-RUN: OWNER=${OWNER} SCRATCH_DIR=${SCRATCH_DIR} HOME_NGINX_CONF=${HOME_NGINX_CONF} ${hook}"
    return 0
  fi
  set +e
  OWNER="${OWNER}" SCRATCH_DIR="${SCRATCH_DIR}" HOME_NGINX_CONF="${HOME_NGINX_CONF}" "${hook}"
  rc=$?
  set -e
  case "${rc}" in
    0)
      echo "on-deploy: changed (will reload/restart when units are active)"
      return 0
      ;;
    1)
      echo "on-deploy: no change"
      return 1
      ;;
    *)
      echo "ERROR: on-deploy failed (exit ${rc})" >&2
      exit "${rc}"
      ;;
  esac
}


print_status() {
  echo "home-warden setup-service status"
  echo "  repo:            ${repo_dir}"
  echo "  owner:           ${OWNER}"
  echo "  scratch:         ${SCRATCH_DIR}"
  echo "  home nginx.conf: ${HOME_NGINX_CONF:-<unset>}"
  echo "  deployed commit: ${DEPLOYED_COMMIT:-$(git -C "${repo_dir}" rev-parse --short HEAD 2>/dev/null || echo '<unset>')}"
  echo "  service log:     ${SCRATCH_DIR}/home-warden.log"
  echo "  nginx error log: ${SCRATCH_DIR}/logs/error.log"
  echo "  nginx access log:${SCRATCH_DIR}/logs/access.log"
  echo "  host name file:  $(config_file_first_line "${host_name_file}" 2>/dev/null || echo '<missing>')"
  echo "  machine-id file: $(config_file_first_line "${host_machine_id_file}" 2>/dev/null || echo '<missing>')"
  echo "  local hostname:  $(current_hostname_short)"
  echo "  local machine-id:$(machine_id_local)"
  if command -v systemctl >/dev/null 2>&1; then
    local label
    local unit
    local en
    local ac
    local pair
    for pair in "socket:home-warden.socket" "service:home-warden.service"; do
      label="${pair%%:*}"
      unit="${pair##*:}"
      en="$(systemctl is-enabled "${unit}" 2>/dev/null || true)"
      ac="$(systemctl is-active "${unit}" 2>/dev/null || true)"
      echo "  ${label} enabled: ${en:-n/a}"
      echo "  ${label} active:  ${ac:-n/a}"
    done
    en="$(systemctl is-enabled nginx.service 2>/dev/null || true)"
    ac="$(systemctl is-active nginx.service 2>/dev/null || true)"
    echo "  distro nginx:   enabled=${en:-n/a} active=${ac:-n/a}"
  fi
}

mask_distro_nginx() {
  echo "Ensuring distro nginx.service does not own 80/443..."
  if systemctl list-unit-files nginx.service >/dev/null 2>&1; then
    run sudo systemctl disable --now nginx.service 2>/dev/null || true
    run sudo systemctl mask nginx.service 2>/dev/null || true
  fi
}

confirm_running() {
  local nginx_procs
  echo "Confirming home-warden is up..."
  systemctl --no-pager --full status home-warden.socket home-warden.service || true
  nginx_procs="$(ps -o user,pid,cmd -C nginx 2>/dev/null || true)"
  if [[ -n "${nginx_procs}" ]]; then
    echo "${nginx_procs}"
  else
    echo "WARNING: no nginx processes visible yet (socket may wait for traffic)" >&2
  fi
}

main() {
  local resolved

  ensure_host_config

  if ! resolved="$(resolve_home_nginx_conf)"; then
    echo "ERROR: set HOME_NGINX_CONF to thehcma/home nginx/server/nginx.conf" >&2
    exit 1
  fi
  HOME_NGINX_CONF="${resolved}"

  if ((status_only)); then
    print_status
    exit 0
  fi

  require_sudo
  check_prerequisites
  prepare_scratch
  validate_nginx_config

  local on_deploy_rc=0
  set +e
  run_on_deploy
  on_deploy_rc=$?
  set -e

  DEPLOYED_COMMIT="$(git -C "${repo_dir}" rev-parse HEAD 2>/dev/null || true)"
  expand_unit "${unit_template_dir}/home-warden.socket" "${system_unit_dir}/home-warden.socket"
  expand_unit "${unit_template_dir}/home-warden.service" "${system_unit_dir}/home-warden.service"

  mask_distro_nginx

  run sudo systemctl daemon-reload
  run sudo systemctl enable --now home-warden.socket

  if systemctl is-active --quiet home-warden.service 2>/dev/null; then
    if ((on_deploy_rc == 0)); then
      # restart (not reload): unit Environment=DEPLOYED_COMMIT=… only refreshes on a new process
      echo "Restarting home-warden.service (on-deploy changed)..."
      run sudo systemctl restart home-warden.service
    fi
  else
    echo "Starting home-warden.service..."
    run sudo systemctl start home-warden.service
  fi

  if ((dry_run == 0)); then
    confirm_running
  fi

  echo
  echo "Follow logs:"
  echo "  tail --follow=name --retry ${SCRATCH_DIR}/home-warden.log"
  echo "  tail --follow=name --retry ${SCRATCH_DIR}/logs/error.log"
  echo "  tail --follow=name --retry ${SCRATCH_DIR}/logs/access.log"
  print_status
}

main "$@"
