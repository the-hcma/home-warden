#!/usr/bin/env bash
# Report SSL certificates nearing expiration under the home-warden cert tree.
#
# Env:
#   CONF_DIR         default: ~/conf/home-warden
#   CERTS_LIVE_DIR   default: $CONF_DIR/certs/live
#   ALERT_DAYS       default: 10
#
# Usage:
#   ./scripts/cert-checker
#   ./scripts/cert-checker --verbose

set -euo pipefail

conf_dir="${CONF_DIR:-${HOME}/conf/home-warden}"
certs_live_dir="${CERTS_LIVE_DIR:-${conf_dir}/certs/live}"
alert_days="${ALERT_DAYS:-10}"
verbose=0

usage() {
  cat <<'EOF'
Usage: cert-checker [--verbose] [-h|--help]

Report certificates under CERTS_LIVE_DIR that expire within ALERT_DAYS (default 10).
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    -v | --verbose) verbose=1 ;;
    -h | --help)
      usage
      exit 0
      ;;
    *)
      echo "Unknown argument: $1" >&2
      usage >&2
      exit 2
      ;;
  esac
  shift
done

if [[ ! -d "${certs_live_dir}" ]]; then
  echo "cert-checker: missing ${certs_live_dir}" >&2
  exit 2
fi

now_epoch="$(date -u +%s)"
host=""
cert=""
end_raw=""
end_epoch=""
days=0
dir=""

shopt -s nullglob
for dir in "${certs_live_dir}"/*/; do
  host="$(basename "${dir}")"
  cert="${dir}/fullchain.pem"
  [[ -f "${cert}" ]] || continue
  end_raw="$(openssl x509 -in "${cert}" -noout -enddate 2>/dev/null | sed 's/^notAfter=//')"
  if [[ -z "${end_raw}" ]]; then
    echo "cert-checker: could not parse ${cert}" >&2
    continue
  fi
  end_epoch="$(date -u -d "${end_raw}" +%s 2>/dev/null || true)"
  if [[ -z "${end_epoch}" ]]; then
    echo "cert-checker: could not parse date '${end_raw}' for ${host}" >&2
    continue
  fi
  days=$(( (end_epoch - now_epoch) / 86400 ))
  if ((verbose)); then
    if ((days > 0)); then
      echo "info: ${host} expires in ${days} day(s) (${end_raw})"
    elif ((days == 0)); then
      echo "info: ${host} expires today (${end_raw})"
    else
      echo "info: ${host} expired $((-days)) day(s) ago (${end_raw})"
    fi
  fi
  if ((days < alert_days)); then
    if ((days > 0)); then
      echo "the SSL certificate for '${host}' will lapse in ${days} day(s)"
    elif ((days == 0)); then
      echo "the SSL certificate for '${host}' will expire today"
    else
      echo "the SSL certificate for '${host}' lapsed $((-days)) day(s) ago"
    fi
  fi
done

exit 0
