#!/usr/bin/env bash
# scripts/on-deploy — deploy hook called by scripts/setup-service.
#
# home-warden has no build step. This hook:
#   1. Ensures scratch layout + modules symlink + empty log files (for tail --retry)
#   2. Optionally validates nginx config (sudo nginx -t when passwordless sudo works)
#   3. Records the deployed git SHA under ~/scratch/home-warden/on-deploy-sha
#
# Exit code contract (consumed by scripts/setup-service):
#   0  — deploy state updated; setup-service should (re)start/reload units
#   1  — nothing changed; skip restart for an already-running service
#   2+ — failure; setup-service aborts
#
# Worktree-aware: repo_dir is resolved from BASH_SOURCE[0].

set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
readonly script_dir
repo_dir="$(cd "${script_dir}/.." && pwd)"
readonly repo_dir

OWNER="${OWNER:-$(id -un)}"
SCRATCH_DIR="${SCRATCH_DIR:-${HOME}/scratch/home-warden}"
HOME_NGINX_CONF="${HOME_NGINX_CONF:-}"
readonly sha_file="${SCRATCH_DIR}/on-deploy-sha"
readonly service_log="${SCRATCH_DIR}/home-warden.log"
readonly error_log="${SCRATCH_DIR}/logs/error.log"
readonly access_log="${SCRATCH_DIR}/logs/access.log"

resolve_home_nginx_conf() {
  if [[ -n "${HOME_NGINX_CONF}" ]]; then
    printf '%s\n' "${HOME_NGINX_CONF}"
    return 0
  fi
  local candidate
  for candidate in \
    "${HOME}/home/nginx/server/nginx.conf" \
    /home/house_meister/home/nginx/server/nginx.conf; do
    if [[ -f "${candidate}" ]]; then
      printf '%s\n' "${candidate}"
      return 0
    fi
  done
  return 1
}

prepare_scratch() {
  mkdir -p \
    "${SCRATCH_DIR}/logs" \
    "${SCRATCH_DIR}/certs/live" \
    "${SCRATCH_DIR}/client_body_temp" \
    "${SCRATCH_DIR}/proxy_temp" \
    "${SCRATCH_DIR}/fastcgi_temp" \
    "${SCRATCH_DIR}/uwsgi_temp" \
    "${SCRATCH_DIR}/scgi_temp"
  if [[ -d /usr/lib/nginx/modules ]]; then
    ln -sfn /usr/lib/nginx/modules "${SCRATCH_DIR}/modules"
  fi
  # Truncate-friendly files so ``tail --follow=name --retry`` works before first write.
  : >>"${service_log}"
  : >>"${error_log}"
  : >>"${access_log}"
  # Ensure the service user can append (system unit runs as OWNER).
  chmod u+rw "${service_log}" "${error_log}" "${access_log}" 2>/dev/null || true
}

validate_nginx_conf() {
  local -r conf="$1"
  if [[ ! -f "${conf}" ]]; then
    echo "on-deploy: nginx conf missing: ${conf}" >&2
    return 2
  fi
  if sudo -n true 2>/dev/null; then
    if sudo -n nginx -p "${SCRATCH_DIR}/" -t -c "${conf}"; then
      echo "on-deploy: nginx -t OK (${conf})"
      return 0
    fi
    echo "on-deploy: nginx -t failed" >&2
    return 2
  fi
  # Unprivileged nginx -t tries to bind 80/443 and fails; syntax-only path unavailable.
  echo "on-deploy: skip nginx -t (no passwordless sudo) — run: sudo nginx -p ${SCRATCH_DIR}/ -t -c ${conf}"
  return 0
}

main() {
  if ! HOME_NGINX_CONF="$(resolve_home_nginx_conf)"; then
    echo "on-deploy: set HOME_NGINX_CONF to thehcma/home nginx/server/nginx.conf" >&2
    exit 2
  fi

  prepare_scratch
  validate_nginx_conf "${HOME_NGINX_CONF}"

  local current_sha=""
  current_sha="$(git -C "${repo_dir}" rev-parse HEAD 2>/dev/null || true)"
  if [[ -z "${current_sha}" ]]; then
    echo "on-deploy: could not resolve HEAD in ${repo_dir}" >&2
    exit 2
  fi

  if [[ -f "${sha_file}" ]]; then
    local deployed_sha=""
    deployed_sha="$(tr -d '[:space:]' <"${sha_file}")"
    if [[ "${deployed_sha}" == "${current_sha}" ]]; then
      echo "Already deployed at ${current_sha:0:7} — no change."
      echo "Logs:"
      echo "  tail --follow=name --retry ${service_log}"
      echo "  tail --follow=name --retry ${error_log}"
      echo "  tail --follow=name --retry ${access_log}"
      exit 1
    fi
  fi

  printf '%s\n' "${current_sha}" >"${sha_file}"
  echo "Recorded deploy at ${current_sha:0:7} (${repo_dir})"
  echo "Owner=${OWNER} scratch=${SCRATCH_DIR} conf=${HOME_NGINX_CONF}"
  echo "Logs:"
  echo "  tail --follow=name --retry ${service_log}"
  echo "  tail --follow=name --retry ${error_log}"
  echo "  tail --follow=name --retry ${access_log}"
  exit 0
}

main "$@"
