# Optional environment for home-warden-certbot.service / scripts/cert-renewer.
# Copy to ~/.config/home-warden-certbot.env and chmod 600.
#
# Domains and Cloudflare token stay in the repo's gitignored conf/ files by default:
#   conf/certbot-domains     (from conf/certbot-domains.example)
#   conf/cloudflare.ini      (from conf/cloudflare.ini.example)
#
# Use real values only in this env file and conf/ — never commit them.

# Let's Encrypt account contact (required for real issuance)
# CERTBOT_EMAIL=admin@example.com

# Overrides (defaults shown):
# SCRATCH_DIR=%h/scratch/home-warden
# CERTBOT_CONFIG_DIR=%h/scratch/home-warden/certs
# CLOUDFLARE_CREDENTIALS=/path/to/home-warden/conf/cloudflare.ini
# CERTBOT_DOMAINS_FILE=/path/to/home-warden/conf/certbot-domains
# CERTBOT=/usr/bin/certbot
# HOME_WARDEN_RELOAD=0
