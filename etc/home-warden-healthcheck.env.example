# Optional environment for home-warden-healthcheck.service / scripts/healthcheck.
# Copy to ~/.config/home-warden-healthcheck.env and chmod 600.
#
# Use a real mailbox only in that local file — never commit addresses.

# Required for email alerts (leave unset to log-only):
# HEALTHCHECK_EMAIL_TO=you@example.com

# HEALTHCHECK_EMAIL_FROM=home-warden@your.host.example
# HEALTHCHECK_HOST=app.example.com
# HEALTHCHECK_URL_PATH=/
# HEALTHCHECK_TIMEOUT_SEC=5
# HEALTHCHECK_OK_STATUSES=200,204,301,302,303,307,308
# HEALTHCHECK_RESEND_SEC=1800
# HEALTHCHECK_SERVICE=home-warden.service
# SCRATCH_DIR=$HOME/scratch/home-warden
