# Local secrets / live certs (never commit)
*.pem
*.key
!nginx/snippets/.gitkeep
certs/
.env
.env.*

# Runtime / scratch
scratch/
*.log
*.pid

# Graphite / start-development stack worktrees
.worktrees/

# Editor / OS
.DS_Store
*.swp

# Local conf (examples stay tracked as conf/*.example)
conf/*
!conf/*.example
!conf/README.md
